{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://judgecalibrator-backend-80302276804.us-central1.run.app/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://saalikahmed.com https://*.saalikahmed.com"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://saalikahmed.com"
        }
      ]
    }
  ]
}
